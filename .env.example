# Razorpay API credentials (from Razorpay Dashboard -> Settings -> API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here

# Owner WhatsApp number for order notifications (country code + number, no + or spaces)
OWNER_WHATSAPP=919999999999

# Local dev server port (not used on Vercel)
PORT=3000
